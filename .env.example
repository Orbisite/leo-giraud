# Optionnel : sans ces variables, le site utilise les défauts dans src/config/remoteData.js
# (branche main de Orbisite/leo-giraud-api).

# VITE_CONTENT_URL=https://raw.githubusercontent.com/ORG/leo-giraud-api/main/content.json
# VITE_THEME_URL=https://raw.githubusercontent.com/ORG/leo-giraud-api/main/theme.json
# VITE_SITE_URL=https://raw.githubusercontent.com/ORG/leo-giraud-api/main/site.json
# VITE_API_IMG_BASE=https://raw.githubusercontent.com/ORG/leo-giraud-api/main/img

# Développement local : servir le dossier du dépôt API (pas orbisite/api sauf copie identique).
# npx serve /chemin/vers/leo-giraud-api -l 8787
# VITE_CONTENT_URL=http://127.0.0.1:8787/content.json
# VITE_THEME_URL=http://127.0.0.1:8787/theme.json
# VITE_SITE_URL=http://127.0.0.1:8787/site.json
# VITE_API_IMG_BASE=http://127.0.0.1:8787/img
